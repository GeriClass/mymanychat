# Banco de dados PostgreSQL.
# Crie um banco gratuito em https://neon.tech (ou use o Postgres do Vercel)
# e cole aqui a connection string (use a versão "pooled" no Vercel).
DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=require"

# URL pública do app (usada no callback OAuth e nos webhooks).
# Em desenvolvimento use um túnel (ngrok, cloudflared) — a Meta exige HTTPS.
APP_URL="https://seu-dominio.com"

# Credenciais do app na Meta (https://developers.facebook.com)
# Produto: "Instagram > API com Login do Instagram"
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""

# Token de verificação do webhook — você inventa esse valor e repete
# no painel da Meta ao configurar o webhook.
WEBHOOK_VERIFY_TOKEN="troque-por-um-valor-secreto"
